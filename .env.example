# Copy to `.env` and fill in locally — `.env` is gitignored.

# Hudl assessment / login suite (`tests/hudl`, project `hudl-chromium`)
# Use the test account Hudl emails separately; never commit real values.
# Aliases also work: HUDL_TEST_EMAIL / HUDL_TEST_PASSWORD, or HUDL_USERNAME for email.
HUDL_EMAIL=
HUDL_PASSWORD=
#
# Alternative: copy `playwright/.secrets/hudl-login.json.example` to
# `playwright/.secrets/hudl-login.json` (gitignored) and fill email/password.

# Optional override (defaults to https://www.hudl.com)
# HUDL_BASE_URL=https://www.hudl.com

# Shared framework (Sauce Demo, docs, API)
# BASE_URL=
# API_BASE_URL=
# TEST_ENV=default
